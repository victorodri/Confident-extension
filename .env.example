# .env.example — Plantilla de variables de entorno
# Copia este archivo como .env.local y rellena los valores reales
# NUNCA subir .env.local a GitHub — está en .gitignore
#
# Nomenclatura:
#   NEXT_PUBLIC_* → se expone al navegador (seguro incluir en cliente)
#   Sin prefijo   → solo disponible en servidor (NUNCA exponer al cliente)

# ─────────────────────────────
# Anthropic (Claude) — PRIVADA
# Usada en: app/api/analyze/route.ts (servidor)
# NUNCA exponer al cliente ni a la extensión
# ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─────────────────────────────
# Deepgram — hay dos versiones
# ─────────────────────────────
# PRIVADA: usada en servidor si se centraliza la conexión Deepgram
DEEPGRAM_API_KEY=

# PÚBLICA: usada en la extensión Chrome (cliente)
# El usuario también puede introducirla manualmente en el popup (MVP actual)
NEXT_PUBLIC_DEEPGRAM_API_KEY=

# ─────────────────────────────
# Supabase — dos claves distintas con permisos distintos
# ─────────────────────────────
# PÚBLICA: URL del proyecto (sin datos sensibles)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co

# PÚBLICA: clave anónima (solo lectura limitada por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# PRIVADA: clave de servicio con acceso total (ignora RLS)
# SOLO en servidor (supabase-server.ts). NUNCA exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─────────────────────────────
# Resend (email transaccional) — PRIVADA
# Usada en: app/api/send-transcript/route.ts (servidor)
# ─────────────────────────────
RESEND_API_KEY=re_...

# Dirección de remitente verificada en Resend
RESEND_FROM_EMAIL=hola@tryconfident.com

# ─────────────────────────────
# Posthog (analytics) — PÚBLICAS
# El tracking se hace desde el navegador, por eso son públicas
# Región EU para cumplir RGPD
# ─────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─────────────────────────────
# App — PÚBLICA
# URL base del frontend (usada en emails, OG tags, etc.)
# ─────────────────────────────
NEXT_PUBLIC_APP_URL=https://tryconfident.com

# ─────────────────────────────
# Stripe — preparado para post-MVP, NO activo ahora
# ─────────────────────────────
# PRIVADA: clave secreta (solo servidor)
STRIPE_SECRET_KEY=sk_test_...

# PÚBLICA: clave publicable (cliente, necesaria para Stripe.js)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
